default_platform(:ios)

# Uploads ONLY the iPhone 6.9" screenshots to App Store Connect using the same
# App Store Connect API key used for TestFlight. Invoked as `fastlane screens`
# from CI. Using a lane (not the bare `deliver` CLI) means every parameter is
# explicit, so deliver never drops into its interactive "setup deliver?" prompt.
platform :ios do
  desc "Upload iPhone 6.9\" screenshots to App Store Connect"
  lane :screens do
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER"],
      key_content: ENV["ASC_KEY"],
      is_key_content_base64: false,
      in_house: false,
    )
    deliver(
      api_key: api_key,
      app_identifier: ENV["BUNDLE_ID"],
      skip_binary_upload: true,
      skip_metadata: true,
      skip_screenshots: false,
      screenshots_path: "fastlane/screenshots",
      overwrite_screenshots: true,
      run_precheck_before_submit: false,
      force: true,
    )
  end

  desc "Attach build BUILD_NUMBER and submit the version for App Store review"
  lane :submit do
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER"],
      key_content: ENV["ASC_KEY"],
      is_key_content_base64: false,
      in_house: false,
    )
    deliver(
      api_key: api_key,
      app_identifier: ENV["BUNDLE_ID"],
      build_number: ENV["BUILD_NUMBER"],
      submit_for_review: true,
      force: true,                       # no interactive HTML preview
      skip_binary_upload: true,          # build already on TestFlight
      skip_screenshots: true,            # screenshots already uploaded
      skip_metadata: true,               # reuse the already-accepted metadata
      run_precheck_before_submit: false,
      submission_information: {
        export_compliance_uses_encryption: false,
        content_rights_contains_third_party_content: false,
        add_id_info_uses_idfa: false,    # AdMob requests non-personalized ads; no tracking/ATT
      },
    )
  end

  desc "Read-only: print the version + review-submission state"
  lane :state do
    Spaceship::ConnectAPI.token = Spaceship::ConnectAPI::Token.create(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER"],
      key: ENV["ASC_KEY"],
    )
    app = Spaceship::ConnectAPI::App.find(ENV["BUNDLE_ID"])
    UI.success("APP: #{app.name} (#{app.id}) #{app.bundle_id}")
    platform = Spaceship::ConnectAPI::Platform::IOS
    begin
      edit = app.get_edit_app_store_version(platform: platform)
      UI.success("EDIT VERSION: #{edit&.version_string} state=#{edit&.app_store_state} build=#{(edit&.build&.version rescue nil)}")
    rescue => e
      UI.error("edit version: #{e.message}")
    end
    begin
      live = app.get_live_app_store_version(platform: platform)
      UI.success("LIVE VERSION: #{live&.version_string} state=#{live&.app_store_state}")
    rescue => e
      UI.message("live version: #{e.message}")
    end
    begin
      sub = app.get_in_progress_review_submission(platform: platform)
      if sub
        UI.success("IN-PROGRESS REVIEW SUBMISSION: id=#{sub.id} state=#{sub.state} submitted=#{(sub.submitted_date rescue nil)}")
        begin
          items = sub.review_submission_items
          UI.success("  items in submission: #{items&.size}")
        rescue => e
          UI.message("  items: #{e.message}")
        end
      else
        UI.success("NO in-progress review submission")
      end
    rescue => e
      UI.error("review submission: #{e.message}")
    end
  end

  desc "Cancel the rejected in-progress submission, then submit the new build for review"
  lane :force_submit do
    Spaceship::ConnectAPI.token = Spaceship::ConnectAPI::Token.create(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER"],
      key: ENV["ASC_KEY"],
    )
    app = Spaceship::ConnectAPI::App.find(ENV["BUNDLE_ID"])
    platform = Spaceship::ConnectAPI::Platform::IOS

    sub = app.get_in_progress_review_submission(platform: platform)
    if sub
      UI.important("Cancelling stale submission #{sub.id} (state=#{sub.state})")
      begin
        if sub.respond_to?(:cancel_submission)
          sub.cancel_submission
        else
          Spaceship::ConnectAPI.patch_review_submission(review_submission_id: sub.id, attributes: { canceled: true })
        end
      rescue => e
        UI.error("cancel attempt error: #{e.message}")
      end
      cleared = false
      36.times do
        cur = app.get_in_progress_review_submission(platform: platform)
        if cur.nil?
          cleared = true
          break
        end
        UI.message("waiting for cancel to clear… state=#{cur.state}")
        sleep 5
      end
      UI.user_error!("Old submission did not clear in time") unless cleared
      UI.success("Stale submission cleared")
    else
      UI.message("No in-progress submission to cancel")
    end

    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER"],
      key_content: ENV["ASC_KEY"],
      is_key_content_base64: false,
      in_house: false,
    )
    deliver(
      api_key: api_key,
      app_identifier: ENV["BUNDLE_ID"],
      build_number: ENV["BUILD_NUMBER"],
      submit_for_review: true,
      force: true,
      skip_binary_upload: true,
      skip_screenshots: true,
      skip_metadata: true,
      run_precheck_before_submit: false,
      submission_information: {
        export_compliance_uses_encryption: false,
        content_rights_contains_third_party_content: false,
        add_id_info_uses_idfa: false,
      },
    )
  end

  desc "Read-only: list edit-version localizations + metadata/screenshot presence"
  lane :locales do
    Spaceship::ConnectAPI.token = Spaceship::ConnectAPI::Token.create(
      key_id: ENV["ASC_KEY_ID"], issuer_id: ENV["ASC_ISSUER"], key: ENV["ASC_KEY"],
    )
    app = Spaceship::ConnectAPI::App.find(ENV["BUNDLE_ID"])
    UI.success("APP #{app.name} primary_locale=#{app.primary_locale}")
    platform = Spaceship::ConnectAPI::Platform::IOS
    ver = app.get_edit_app_store_version(platform: platform)
    UI.success("EDIT VERSION #{ver&.version_string} state=#{ver&.app_store_state}")
    locs = ver.get_app_store_version_localizations
    locs.each do |l|
      desc = l.description.to_s.strip
      kw = l.keywords.to_s.strip
      shots = 0
      begin
        sets = l.get_app_screenshot_sets
        sets.each { |s| shots += (s.app_screenshots || []).size }
      rescue => e
        shots = "err:#{e.message}"
      end
      UI.important("locale=#{l.locale} desc=#{desc.empty? ? 'MISSING' : desc.length.to_s+'ch'} kw=#{kw.empty? ? 'MISSING' : 'ok'} support=#{l.support_url.inspect} shots=#{shots}")
    end
  end

  desc "Delete the localization named in DEL_LOCALE from the edit version"
  lane :del_locale do
    Spaceship::ConnectAPI.token = Spaceship::ConnectAPI::Token.create(
      key_id: ENV["ASC_KEY_ID"], issuer_id: ENV["ASC_ISSUER"], key: ENV["ASC_KEY"],
    )
    app = Spaceship::ConnectAPI::App.find(ENV["BUNDLE_ID"])
    ver = app.get_edit_app_store_version(platform: Spaceship::ConnectAPI::Platform::IOS)
    target = ENV["DEL_LOCALE"]
    loc = ver.get_app_store_version_localizations.find { |l| l.locale == target }
    if loc
      loc.delete!
      UI.success("Deleted localization #{target}")
    else
      UI.message("Locale #{target} not present; nothing to delete")
    end
  end

  desc "Read-only: latest TestFlight builds + beta groups"
  lane :tf do
    Spaceship::ConnectAPI.token = Spaceship::ConnectAPI::Token.create(
      key_id: ENV["ASC_KEY_ID"], issuer_id: ENV["ASC_ISSUER"], key: ENV["ASC_KEY"],
    )
    app = Spaceship::ConnectAPI::App.find(ENV["BUNDLE_ID"])
    UI.success("APP #{app.name} (#{app.id})")
    begin
      builds = app.get_builds(includes: "preReleaseVersion", limit: 6)
      builds.each do |b|
        ver = (b.pre_release_version && b.pre_release_version.version) rescue "?"
        UI.important("BUILD #{ver} (#{b.version}) state=#{b.processing_state} expired=#{b.expired} uploaded=#{(b.uploaded_date rescue nil)}")
      end
    rescue => e
      UI.error("builds: #{e.message}")
    end
    begin
      groups = app.get_beta_groups
      groups.each do |g|
        UI.success("GROUP '#{g.name}' internal=#{(g.is_internal_group rescue '?')} publicLink=#{(g.public_link rescue nil)}")
      end
    rescue => e
      UI.error("groups: #{e.message}")
    end
  end

  desc "Push the latest build to the beta tester groups (re-notify testers)"
  lane :distribute do
    Spaceship::ConnectAPI.token = Spaceship::ConnectAPI::Token.create(
      key_id: ENV["ASC_KEY_ID"], issuer_id: ENV["ASC_ISSUER"], key: ENV["ASC_KEY"],
    )
    app = Spaceship::ConnectAPI::App.find(ENV["BUNDLE_ID"])
    build = app.get_builds(limit: 1).first
    UI.user_error!("No builds found") unless build
    ver = (build.pre_release_version && build.pre_release_version.version) rescue "?"
    UI.success("Latest build: #{ver} (#{build.version}) state=#{build.processing_state}")
    groups = app.get_beta_groups
    groups.each do |g|
      internal = (g.is_internal_group rescue nil)
      begin
        build.add_beta_groups(beta_groups: [g])
        UI.success("→ distributed to '#{g.name}' (internal=#{internal})")
      rescue => e
        UI.error("could not add to '#{g.name}': #{e.message}")
      end
    end
    UI.success("Done — internal testers are notified now; external groups queue for Beta App Review.")
  end

end
