default_platform(:ios)

# Uploads ONLY the iPhone 6.9" screenshots to App Store Connect using the same
# App Store Connect API key used for TestFlight. Invoked as `fastlane screens`
# from CI. Using a lane (not the bare `deliver` CLI) means every parameter is
# explicit, so deliver never drops into its interactive "setup deliver?" prompt.
platform :ios do
  desc "Upload iPhone 6.9\" screenshots to App Store Connect"
  lane :screens do
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER"],
      key_content: ENV["ASC_KEY"],
      is_key_content_base64: false,
      in_house: false,
    )
    deliver(
      api_key: api_key,
      app_identifier: ENV["BUNDLE_ID"],
      skip_binary_upload: true,
      skip_metadata: true,
      skip_screenshots: false,
      screenshots_path: "fastlane/screenshots",
      overwrite_screenshots: true,
      run_precheck_before_submit: false,
      force: true,
    )
  end

  desc "Attach build BUILD_NUMBER and submit the version for App Store review"
  lane :submit do
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER"],
      key_content: ENV["ASC_KEY"],
      is_key_content_base64: false,
      in_house: false,
    )
    deliver(
      api_key: api_key,
      app_identifier: ENV["BUNDLE_ID"],
      build_number: ENV["BUILD_NUMBER"],
      submit_for_review: true,
      force: true,                       # no interactive HTML preview
      skip_binary_upload: true,          # build already on TestFlight
      skip_screenshots: true,            # screenshots already uploaded
      skip_metadata: true,               # reuse the already-accepted metadata
      run_precheck_before_submit: false,
      submission_information: {
        export_compliance_uses_encryption: false,
        content_rights_contains_third_party_content: false,
        add_id_info_uses_idfa: false,    # AdMob requests non-personalized ads; no tracking/ATT
      },
    )
  end
end
